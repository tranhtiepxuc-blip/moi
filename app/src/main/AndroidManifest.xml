<manifest xmlns:android="[http://schemas.android.com/apk/res/xml](http://schemas.android.com/apk/res/xml)"
    package="com.privatevcam.fms"> <!-- Đổi tên gói này thành bất cứ tên gì bạn muốn để tránh bị phát hiện -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Hệ Thống Hỗ Trợ FMS"
        android:theme="@style/Theme.AppCompat">

        <!-- Kích hoạt Xposed Module -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        
        <!-- Mô tả module hiển thị trong LSPosed -->
        <meta-data
            android:name="xposeddescription"
            android:value="Công cụ hỗ trợ tối ưu hóa hình ảnh thực địa FMS" />
        
        <!-- Phiên bản Xposed tối thiểu -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

    </application>
</manifest>
